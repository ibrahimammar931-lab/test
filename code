students = {
    "Alice": [15, 18, 14],
    "Bob": [10, 12, 11],
    "Charlie": [19, 17, 18]
}

def average(grades):
    if len(grades) == 0:
        return 0
    try:
        return sum(grades) / len(grades)
    except ZeroDivisionError:
        return 0
    except TypeError:
        raise ValueError("Grades must be numeric")

def display_results():
    if not students:
        print("No students found")
        return
    print("Student Results")
    print("-" * 30)

    for name, grades in students.items():
        if not grades:
            print(f"{name}: No grades found")
            continue
        try:
            avg = average(grades)
        except ValueError as e:
            print(f"{name}: {e}")
            continue

        if avg >= 16:
            status = "Excellent"
        elif avg >= 10:
            status = "Passed"
        else:
            status = "Failed"

        print(f"{name}: Average = {avg:.2f} | {status}")

display_results()